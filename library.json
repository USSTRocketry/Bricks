{
  "name": "Bricks",
  "version": "1.0.0",
  "description": "Utility repo for all avionics software",
  "keywords": [
    "avionics",
    "utility"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/USSTRocketry/Bricks.git"
  },
  "build": {
    "flags": [
      "-std=c++20"
    ],
    "srcFilter": [
      "+<DataStructure/>",
      "+<DataStructure/Buffer/>",
      "+<DataStructure/StateMachine/>"
    ],
    "includeDir": "."
  }
}
